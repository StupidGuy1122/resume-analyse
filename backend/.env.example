# Ollama 服务地址（容器内为 http://ollama:11434）
OLLAMA_HOST=http://localhost:11434

# 默认模型 — 可换 llama3.1:8b / qwen2.5:14b 等
OLLAMA_MODEL=qwen2.5:7b

# 单次模型调用超时（秒）
OLLAMA_TIMEOUT=120

# CORS 允许来源，逗号分隔
CORS_ORIGINS=http://localhost:3000

# 上传大小上限（MB）
MAX_UPLOAD_MB=10

# SQLite 数据库路径（相对 backend/，会自动创建）
DB_PATH=data/app.db

# 登录账号（无注册功能，唯一账号）
AUTH_USERNAME=admin
AUTH_PASSWORD=changeme

# Cookie HMAC 签名密钥 — 部署到任何地方都要换成 32+ 随机字符
AUTH_SECRET=please-change-this-to-a-long-random-string-32chars-or-more
AUTH_SESSION_DAYS=30
